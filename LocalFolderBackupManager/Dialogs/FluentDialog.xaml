<ui:FluentWindow x:Class="LocalFolderBackupManager.Dialogs.FluentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="420"
        MaxHeight="400"
        Icon="/Assets/sync.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Minimal title bar — drag surface only, no visible title text -->
        <ui:TitleBar Grid.Row="0"
                     ShowMaximize="False"
                     ShowMinimize="False"
                     ShowClose="True"
                     Icon="/Assets/sync.ico"
                     Height="36"/>

        <!-- Content -->
        <Border Grid.Row="1" Padding="24,12,24,20">
            <StackPanel>

                <!-- Icon + Title row -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                    <Border x:Name="IconBorder"
                            Width="36" Height="36"
                            CornerRadius="18"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="IconText"
                                   FontSize="17"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock x:Name="TitleText"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </StackPanel>

                <!-- Message -->
                <TextBlock x:Name="MessageText"
                           TextWrapping="Wrap"
                           FontSize="13"
                           LineHeight="20"
                           Margin="0,0,0,16"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                <!-- Buttons -->
                <StackPanel x:Name="ButtonPanel" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button x:Name="SecondaryButton"
                               Content="No"
                               Margin="0,0,8,0"
                               Height="32"
                               Padding="18,0"
                               Visibility="Collapsed"
                               Click="SecondaryButton_Click"/>

                    <ui:Button x:Name="PrimaryButton"
                               Content="OK"
                               Height="32"
                               Padding="18,0"
                               Click="PrimaryButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
