<ui:FluentWindow x:Class="LocalFolderBackupManager.Dialogs.FolderSelectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Select Folders to Filter"
        WindowStartupLocation="CenterOwner"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        ResizeMode="CanResize"
        Width="900"
        Height="700"
        MinWidth="700"
        MinHeight="500"
        Icon="/Assets/sync.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <ui:TitleBar Grid.Row="0"
                     Title="Select Folders to Filter"
                     ShowMaximize="True"
                     ShowMinimize="False"
                     Icon="/Assets/sync.ico"/>

        <!-- Content -->
        <Border Grid.Row="1" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Source path display -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Source Folder:" 
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>
                    <TextBlock x:Name="SourcePathText"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- Folder list with checkboxes -->
                <Border Grid.Row="2" 
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="4"
                        Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Description text in first row -->
                            <StackPanel Grid.Row="0">
                                <TextBlock x:Name="FilterDescriptionText"
                                           Text="Select folders to add to filter:"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Tip: Selecting a parent folder will exclude it and all its subdirectories"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <!-- Controls in second row -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="15"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Depth limit dropdown -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Display Depth:"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <ComboBox x:Name="DepthLimitComboBox"
                                              MinWidth="240"
                                              Height="36"
                                              VerticalAlignment="Center"
                                              ToolTip="Limit how many folder levels to display and select"
                                              SelectionChanged="DepthLimitComboBox_SelectionChanged"/>
                                </StackPanel>

                                <!-- Selection button on the right -->
                                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <ui:Button Content="Select All"
                                               Height="36"
                                               Padding="20,0"
                                               ToolTip="Select all folders up to the selected depth limit"
                                               Click="SelectAllButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TreeView x:Name="FoldersTreeView"
                                          BorderThickness="0"
                                          Background="Transparent">
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <CheckBox Content="{Binding Name}"
                                                      IsChecked="{Binding IsSelected}"
                                                      Margin="0,2"/>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>

                                <!-- Message when no folders found -->
                                <TextBlock x:Name="NoFoldersMessage"
                                           Text="No subfolders found in the source path."
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontStyle="Italic"
                                           Visibility="Collapsed"
                                           Margin="0,10,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Selection info -->
                <TextBlock x:Name="SelectionInfoText"
                           Grid.Row="4"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12"/>
            </Grid>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="2" 
                Padding="20,10,20,20">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <ui:Button Content="Cancel"
                           Click="CancelButton_Click"
                           Height="36"
                           Padding="20,0"
                           Margin="0,0,10,0"/>
                <ui:Button Content="Add Selected"
                           Click="AddButton_Click"
                           Appearance="Primary"
                           Height="36"
                           Padding="20,0"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
