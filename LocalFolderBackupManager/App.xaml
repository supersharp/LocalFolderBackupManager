<Application x:Class="LocalFolderBackupManager.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:LocalFolderBackupManager.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <conv:InverseBooleanConverter x:Key="InverseBoolConverter"/>
            <conv:HexColorToBrushConverter x:Key="HexColorToBrushConverter"/>
            <conv:StringEmptyToBoolConverter x:Key="StringEmptyToBoolConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>


