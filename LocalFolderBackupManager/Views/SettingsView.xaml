<Page x:Class="LocalFolderBackupManager.Views.SettingsView" TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Settings">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Settings"
                       FontSize="32"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="30"
                    Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="⏰" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Scheduled Tasks"
                                   FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               LineHeight="22"
                               Margin="0,0,0,0">
                        Scheduled tasks are now managed from the dedicated
                        <Run Text="Schedule" FontWeight="SemiBold"/>
                        page in the sidebar. You can create multiple custom schedules
                        (At Logon, Daily, Weekly, or Hourly) and view their live status there.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="30">
                <StackPanel>
                    <TextBlock Text="ℹ️ About"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,15"/>

                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               LineHeight="22">
                        <Run Text="Save Game Backup Manager" FontWeight="SemiBold"/>
                        <LineBreak/>
                        <Run Text="Version 1.0.0"/>
                        <LineBreak/>
                        <LineBreak/>
                        <Run Text="A simple folder backup utility."/>
                        <LineBreak/>
                        <LineBreak/>
                        <Run Text="Created by Tahir"/>
                        <LineBreak/>
                        <LineBreak/>
                        <Run Text="Configuration is stored in backup_config.json in the application directory."/>
                        <LineBreak/>
                        <Run Text="Logs are stored in C:\Save_Game_Backup_Logs"/>
                        <LineBreak/>
                        <LineBreak/>
                        <Run Text="Built with .NET 10 and ModernWpf UI"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
