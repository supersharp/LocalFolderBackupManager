<Page x:Class="LocalFolderBackupManager.Views.ScheduleView"
      TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Schedule">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">

            <!-- ══ Header ══ -->
            <StackPanel Margin="0,0,0,6">
                <TextBlock Text="&#x23F0; Schedule" FontSize="32" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="Create Windows Scheduled Tasks to automate your backups."
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="14"/>
            </StackPanel>

            <!-- ══ Stale-path warning banner ══ -->
            <Border Background="#3DE74C3C"
                    BorderBrush="#E74C3C"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,12"
                    Margin="0,12,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasStale}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x26A0;&#xFE0F;" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock TextWrapping="Wrap" VerticalAlignment="Center">
                        <Run Text="One or more tasks point to an exe path that no longer exists." FontWeight="SemiBold"/>
                        <LineBreak/>
                        <Run Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             Text="This can happen when the application is moved or run from a new location. Use the "/>
                        <Run Text="Update Path" FontWeight="SemiBold"/>
                        <Run Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                             Text=" button on affected tasks to fix them."/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ══════════════ CREATE TASK FORM ══════════════ -->
            <Expander Background="{DynamicResource ControlFillColorDefaultBrush}"
                      Margin="0,16,0,20"
                      IsExpanded="False"
                      Header="➕ Add New Schedule">
                <Border Padding="20,10,20,20" CornerRadius="10">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                        <!-- Task Name -->
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Task Name *"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <ui:TextBox PlaceholderText="e.g. Save_Game_Backup_Daily"
                                        Text="{Binding NewTaskName, UpdateSourceTrigger=PropertyChanged}"
                                        Height="38"/>
                        </StackPanel>

                        <!-- Trigger Type -->
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Trigger Type"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding TriggerTypes}"
                                      SelectedItem="{Binding NewTriggerType}"
                                      Height="38"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <!-- Description -->
                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3">
                            <TextBlock Text="Description (optional)"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <ui:TextBox PlaceholderText="What does this schedule do?"
                                        Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}"
                                        Height="38"/>
                        </StackPanel>

                        <!-- Time of Day (Daily / Weekly) -->
                        <StackPanel Grid.Row="4" Grid.Column="0"
                                    Visibility="{Binding ShowTimePicker, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Time of Day (HH:mm)"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <ui:TextBox PlaceholderText="08:00"
                                        Text="{Binding NewTimeOfDay, UpdateSourceTrigger=PropertyChanged}"
                                        Height="38"/>
                        </StackPanel>

                        <!-- Day of Week (Weekly) -->
                        <StackPanel Grid.Row="4" Grid.Column="2"
                                    Visibility="{Binding ShowDayPicker, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Day of Week"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding DaysOfWeek}"
                                      SelectedItem="{Binding NewDayOfWeek}"
                                      Height="38"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <!-- Interval (Hourly) -->
                        <StackPanel Grid.Row="4" Grid.Column="0"
                                    Visibility="{Binding ShowIntervalPicker, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="Repeat Every (hours)"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding HourIntervals}"
                                      SelectedItem="{Binding NewIntervalHours}"
                                      Height="38"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <!-- Submit row -->
                        <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Validation hint (only shown when form is invalid) -->
                            <TextBlock Grid.Column="0"
                                       Text="&#x26A0;&#xFE0F; Task name is required and must be unique."
                                       Foreground="#E67E22"
                                       FontSize="13"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsFormValid}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <ui:Button Grid.Column="2"
                                       Content="&#x2705; Create Scheduled Task"
                                       Appearance="Success"
                                       Height="42"
                                       Padding="24,0"
                                       FontSize="14"
                                       Command="{Binding AddScheduleCommand}"/>
                        </Grid>
                    </Grid>

                                <!-- Busy indicator -->
                                <TextBlock Text="{Binding BusyMessage}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="13"
                                           Margin="0,14,0,0"
                                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>
                    </Expander>

            <!-- ══════════════ TASK LIST ══════════════ -->
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="10"
                    Padding="28">
                <StackPanel>

                    <!-- Section header -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4CB;" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Active Schedules"
                                       FontSize="20" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <ui:Button Grid.Column="1"
                                   Content="&#x1F504; Refresh &amp; Sync"
                                   Command="{Binding RefreshCommand}"
                                   Height="34" Padding="14,0"
                                   ToolTip="Re-scan the Task Scheduler folder and sync with saved config"/>
                    </Grid>

                    <!-- Empty state -->
                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            CornerRadius="8" Padding="32"
                            HorizontalAlignment="Stretch">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasNoSchedules}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#x1F4ED;" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="No scheduled tasks yet."
                                       FontSize="15" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="Use the form above to create your first backup schedule."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="13" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Schedule cards -->
                    <ItemsControl ItemsSource="{Binding Schedules}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Outer card -->
                                <Border CornerRadius="8"
                                        Margin="0,0,0,10"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}">

                                    <!-- Stale highlight border (inner) -->
                                    <Border CornerRadius="8" BorderThickness="1.5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStale}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#E74C3C"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel>
                                            <!-- Main card row -->
                                            <Border Padding="18,14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Trigger icon -->
                                                    <Border Grid.Column="0"
                                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                            CornerRadius="8"
                                                            Width="48" Height="48">
                                                        <TextBlock Text="{Binding TriggerIcon}"
                                                                   FontSize="22"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Task info -->
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                            <TextBlock Text="{Binding TaskName}"
                                                                       FontSize="15" FontWeight="SemiBold"
                                                                       Margin="0,0,10,0"/>
                                                            <!-- Status badge -->
                                                            <Border CornerRadius="4"
                                                                    Padding="8,2"
                                                                    VerticalAlignment="Center"
                                                                    Background="{Binding StatusColour,
                                                                        Converter={StaticResource HexColorToBrushConverter}}">
                                                                <TextBlock Text="{Binding LiveStatus}"
                                                                           FontSize="11" FontWeight="SemiBold"
                                                                           Foreground="White"/>
                                                            </Border>
                                                        </StackPanel>

                                                        <TextBlock Text="{Binding TriggerSummary}"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   FontSize="13" Margin="0,0,0,2"/>

                                                        <TextBlock Text="{Binding Description}"
                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                   FontSize="12"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Visibility="{Binding HasDescription,
                                                                       Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    </StackPanel>

                                                    <!-- Update path button (stale tasks only) -->
                                                    <ui:Button Grid.Column="3"
                                                               Content="&#x1F527; Update Path"
                                                               Appearance="Caution"
                                                               Height="36" Padding="12,0"
                                                               FontSize="13"
                                                               ToolTip="{Binding ExePath, StringFormat='Stale path: {0}'}"
                                                               Command="{Binding DataContext.UpdatePathCommand,
                                                                   RelativeSource={RelativeSource AncestorType=Page}}"
                                                               CommandParameter="{Binding}"
                                                               Visibility="{Binding IsStale,
                                                                   Converter={StaticResource BoolToVisibilityConverter}}"/>

                                                    <!-- Edit button -->
                                                    <ui:Button Grid.Column="5"
                                                               Content="&#x270F;&#xFE0F;"
                                                               Appearance="Primary"
                                                               FontSize="16"
                                                               Width="40" Height="40"
                                                               Padding="0"
                                                               ToolTip="Edit this schedule"
                                                               Command="{Binding DataContext.EditScheduleCommand,
                                                                   RelativeSource={RelativeSource AncestorType=Page}}"
                                                               CommandParameter="{Binding}"/>

                                                    <!-- Delete button -->
                                                    <ui:Button Grid.Column="7"
                                                               Content="&#x1F5D1;&#xFE0F;"
                                                               Appearance="Danger"
                                                               FontSize="16"
                                                               Width="40" Height="40"
                                                               Padding="0"
                                                               ToolTip="Remove this scheduled task"
                                                               Command="{Binding DataContext.DeleteScheduleCommand,
                                                                   RelativeSource={RelativeSource AncestorType=Page}}"
                                                               CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>

                                            <!-- Assigned folders section -->
                                            <Border Padding="18,0,18,10"
                                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                    Visibility="{Binding HasAssignedFolders,
                                                        Converter={StaticResource BoolToVisibilityConverter}}">
                                                <StackPanel>
                                                    <TextBlock Text="Assigned Backup Rules:"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Margin="0,8,0,6"/>
                                                    <ItemsControl ItemsSource="{Binding AssignedFolderNames}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                    <TextBlock Text="📁" FontSize="11" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding}"
                                                                               FontSize="12"
                                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>

                                            <!-- Stale path strip (shown below card when stale) -->
                                            <Border Padding="18,8,18,10"
                                                    Background="#3DE74C3C"
                                                    CornerRadius="0,0,8,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsStale}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#x26A0;&#xFE0F; Stale path: "
                                                               Foreground="#FF6B6B"
                                                               FontSize="12" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding ExePath}"
                                                               Foreground="#FF6B6B"
                                                               FontFamily="Consolas"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
