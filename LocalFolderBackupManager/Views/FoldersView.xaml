<Page x:Class="LocalFolderBackupManager.Views.FoldersView" TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Folders">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Page header with dirty indicator -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Folder Configuration"
                           FontSize="32"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <!-- Unsaved changes badge -->
                <Border Grid.Column="2"
                        VerticalAlignment="Center"
                        Margin="14,4,0,0"
                        Padding="10,4"
                        CornerRadius="4"
                        Background="#3DE67E22">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="#E67E22"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Unsaved changes"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#E67E22"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="30" 
                    Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="📁 Custom Backup Folders"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"/>
                            <TextBlock Text="Add multiple source folders and select where their backups should be stored."
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Top">
                            <ui:Button Content="💾 Save Configuration"
                                       Appearance="Success"
                                       Command="{Binding SaveCommand}"
                                       Height="36" Padding="15,0"
                                       Margin="0,0,0,10"
                                       HorizontalAlignment="Stretch"/>
                            <ui:Button Content="➕ Add Folder" 
                                       Command="{Binding AddFolderCommand}"
                                       Appearance="Primary"
                                       Height="36" Padding="15,0"
                                       HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding CustomFolders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Background="{DynamicResource ControlFillColorSecondaryBrush}" 
                                          Margin="0,0,0,15"
                                          IsExpanded="False">
                                    <Expander.Header>
                                        <Grid Margin="0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" 
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding Name, Mode=OneWay, TargetNullValue='Unnamed Backup Rule'}"/>
                                                <Run Text=" - " Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <Run Text="{Binding SourcePath, Mode=OneWay, TargetNullValue='No source selected'}" 
                                                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                     FontWeight="Normal"
                                                     FontSize="13"/>
                                            </TextBlock>
                                        </Grid>
                                    </Expander.Header>

                                    <Border Padding="15,10,15,15">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="15"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="15"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Name -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Name:" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <ui:TextBox Grid.Column="1" 
                                                            Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                            PlaceholderText="e.g., Game Saves, Documents, etc."
                                                            Height="36" 
                                                            Margin="5,0"/>
                                            </Grid>

                                            <!-- Source -->
                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Source:" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <Grid Grid.Column="1" Margin="5,0">
                                                    <ui:TextBox Text="{Binding SourcePath, UpdateSourceTrigger=PropertyChanged}"
                                                                PlaceholderText="Click here to select source folder..."
                                                                Height="36"
                                                                IsReadOnly="True"
                                                                Padding="10,0,40,0"
                                                                Cursor="Hand"
                                                                MouseDown="SourceTextBox_MouseDown"/>
                                                    <ui:Button HorizontalAlignment="Right"
                                                               Margin="0,0,4,0"
                                                               VerticalAlignment="Center"
                                                               Width="32"
                                                               Height="28"
                                                               Command="{Binding BrowseSourceCommand}"
                                                               Padding="0">
                                                        <ui:Button.Style>
                                                            <Style TargetType="ui:Button">
                                                                <Setter Property="Icon" Value="{ui:SymbolIcon Folder24}"/>
                                                                <Setter Property="ToolTip" Value="Browse for source folder"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SourcePath, Converter={StaticResource StringEmptyToBoolConverter}}" Value="False">
                                                                        <Setter Property="Icon" Value="{x:Null}"/>
                                                                        <Setter Property="Content" Value="✏️"/>
                                                                        <Setter Property="FontSize" Value="16"/>
                                                                        <Setter Property="ToolTip" Value="Change source folder"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:Button.Style>
                                                    </ui:Button>
                                                </Grid>
                                            </Grid>

                                            <!-- Destination -->
                                            <Grid Grid.Row="4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Destination:" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <Grid Grid.Column="1" Margin="5,0">
                                                    <ui:TextBox Text="{Binding DestinationPath, UpdateSourceTrigger=PropertyChanged}"
                                                                PlaceholderText="Click here to select destination folder..."
                                                                Height="36"
                                                                IsReadOnly="True"
                                                                Padding="10,0,40,0"
                                                                Cursor="Hand"
                                                                MouseDown="DestinationTextBox_MouseDown"/>
                                                    <ui:Button HorizontalAlignment="Right"
                                                               Margin="0,0,4,0"
                                                               VerticalAlignment="Center"
                                                               Width="32"
                                                               Height="28"
                                                               Command="{Binding BrowseDestinationCommand}"
                                                               Padding="0">
                                                        <ui:Button.Style>
                                                            <Style TargetType="ui:Button">
                                                                <Setter Property="Icon" Value="{ui:SymbolIcon Folder24}"/>
                                                                <Setter Property="ToolTip" Value="Browse for destination folder"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DestinationPath, Converter={StaticResource StringEmptyToBoolConverter}}" Value="False">
                                                                        <Setter Property="Icon" Value="{x:Null}"/>
                                                                        <Setter Property="Content" Value="✏️"/>
                                                                        <Setter Property="FontSize" Value="16"/>
                                                                        <Setter Property="ToolTip" Value="Change destination folder"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ui:Button.Style>
                                                    </ui:Button>
                                                </Grid>
                                            </Grid>

                                                                                  <!-- Filter Mode & Add Filter -->
                                                                                  <Grid Grid.Row="6">
                                                                                      <Grid.ColumnDefinitions>
                                                                                          <ColumnDefinition Width="130"/>
                                                                                          <ColumnDefinition Width="*"/>
                                                                                          <ColumnDefinition Width="10"/>
                                                                                          <ColumnDefinition Width="130"/>
                                                                                          <ColumnDefinition Width="10"/>
                                                                                          <ColumnDefinition Width="130"/>
                                                                                      </Grid.ColumnDefinitions>
                                                                   <TextBlock Text="Filter Mode:" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                   <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableFilterModes}" SelectedItem="{Binding FilterMode}" Height="36" Margin="5,0" HorizontalAlignment="Stretch" VerticalContentAlignment="Center" Padding="10,0,30,0"/>
                                                                   <ui:Button Grid.Column="3" Content="🗑️ Clear All" Appearance="Danger" Command="{Binding ClearAllFiltersCommand}" Height="36" HorizontalAlignment="Stretch"/>
                                                                   <ui:Button Grid.Column="5" Content="➕ Add Filter" Appearance="Success" Command="{Binding AddFilterCommand}" Height="36" HorizontalAlignment="Stretch"/>
                                                               </Grid>

                                            <!-- Filters List -->
                                            <ItemsControl Grid.Row="8" ItemsSource="{Binding FilteredFiltersView}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="135,0,0,5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="30"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="5"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="10"/>
                                                                <ColumnDefinition Width="2*"/>
                                                                <ColumnDefinition Width="10"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding SymbolText}" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                            <ui:TextBox Grid.Column="1" Text="{Binding Pattern, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Pattern (e.g. *.tmp)" Height="36"/>
                                                            <ui:Button Grid.Column="3" 
                                                                       Icon="{ui:SymbolIcon Folder24}"
                                                                       ToolTip="Browse folders to add"
                                                                       Command="{Binding BrowseFoldersCommand}"
                                                                       Height="36"
                                                                       Width="36"
                                                                       Padding="0"/>
                                                            <ui:TextBox Grid.Column="5" Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Description" Height="36"/>
                                                            <ui:Button Grid.Column="7" Content="❌" Appearance="Danger" Command="{Binding RemoveCommand}" Height="36"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Schedules -->
                                            <Grid Grid.Row="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Schedules:" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding SchedulesSummary}"
                                                           VerticalAlignment="Center"
                                                           Margin="5,0"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <ui:Button Grid.Column="3"
                                                           Content="⏰ Manage Schedules"
                                                           Command="{Binding ManageSchedulesCommand}"
                                                           Height="36"
                                                           Padding="15,0"/>
                                            </Grid>

                                            <!-- Remove Button -->
                                            <Grid Grid.Row="12">
                                                <ui:Button Content="🗑️ Remove This Backup Rule" 
                                                           Appearance="Danger"
                                                           Command="{Binding RemoveCommand}"
                                                           HorizontalAlignment="Right"
                                                           Height="36"
                                                           Padding="15,0"
                                                           Margin="0,0,0,0"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>




        </StackPanel>
    </ScrollViewer>
</Page>
