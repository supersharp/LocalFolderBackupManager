<Page x:Class="LocalFolderBackupManager.Views.DashboardView" TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Dashboard">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="📊 Dashboard" FontSize="32" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- Quick Actions -->
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}" 
                    CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="⚡ Quick Actions" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <ui:Button Content="💾 Backup Now" 
                                Command="{Binding BackupNowCommand}"
                                IsEnabled="{Binding IsBackingUp, Converter={StaticResource InverseBoolConverter}}"
                                Appearance="Primary"
                                Padding="20,10" FontSize="14" Margin="0,0,10,0"/>

                        <ui:Button Content="🔄 Restore" 
                                Command="{Binding RestoreCommand}"
                                IsEnabled="{Binding IsBackingUp, Converter={StaticResource InverseBoolConverter}}"
                                Padding="20,10" FontSize="14" Margin="0,0,10,0"/>

                        <ui:Button Content="🔃 Refresh Stats" 
                                Command="{Binding RefreshCommand}"
                                Padding="20,10" FontSize="14"/>
                    </StackPanel>

                    <!-- Progress Bar -->
                    <ProgressBar Height="6" 
                                 Value="{Binding BackupProgress}"
                                 Maximum="100"
                                 Visibility="{Binding IsBackingUp, Converter={StaticResource BoolToVisibilityConverter}}"
                                 Margin="0,0,0,10"/>

                    <TextBlock Text="{Binding BackupStatusMessage}" 
                               FontSize="13"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- Statistics Cards -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Last Backup Card -->
                <Border Grid.Column="0" 
                        Background="{DynamicResource ControlFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="🕒 Last Backup" FontSize="14" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding LastBackupDate}" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Backup Size Card -->
                <Border Grid.Column="1" 
                        Background="{DynamicResource ControlFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="💽 Backup Size" FontSize="14" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding BackupSize}" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Task Status Card -->
                <Border Grid.Column="2" 
                        Background="{DynamicResource ControlFillColorDefaultBrush}" 
                        CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="⏰ Scheduled Task" FontSize="14" 
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding TaskStatus}" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Information Section -->
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}" 
                    CornerRadius="8" Padding="20" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="ℹ️ Information" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" LineHeight="22">
                        <Run Text="• Use "/><Run Text="'Backup Now'" FontWeight="SemiBold"/><Run Text=" to manually create a backup of your save game folders."/>
                        <LineBreak/>
                        <Run Text="• The "/><Run Text="'Restore'" FontWeight="SemiBold"/><Run Text=" button will copy files from the backup back to the original locations."/>
                        <LineBreak/>
                        <Run Text="• Configure backup folders in the "/><Run Text="'Folders'" FontWeight="SemiBold"/><Run Text=" section."/>
                        <LineBreak/>
                        <Run Text="• Set up automatic backups in the "/><Run Text="'Settings'" FontWeight="SemiBold"/><Run Text=" section."/>
                        <LineBreak/>
                        <Run Text="• Exclude specific folders (like 'Screenshots') in the "/><Run Text="'Filters'" FontWeight="SemiBold"/><Run Text=" section."/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
